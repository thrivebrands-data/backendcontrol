ENV=dev
APP_NAME=Thrive Control Center
CORS_ORIGINS=http://localhost:9875,http://127.0.0.1:9875
PORT=9876

DATA_DIR=./data
RUNS_DIR=./data/runs
# Point at your repo copy of clients (example if backend lives next to the old Python app):
CLIENTS_CONFIG_PATH=../thrive_control_center/clients.yaml

MONGODB_URI=
MONGODB_DB=thrive_control_center

MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=
MYSQL_PORT=3306

LAUNCH_SCRIPTS_IN_TERMINAL=true

# ---- Production notes ----
#
# If you deploy frontend and use Next.js proxy (/api -> backend), CORS is not needed.
# If you call backend directly from browser (NEXT_PUBLIC_API_BASE_URL points to backend),
# set CORS_ORIGINS to your frontend domain(s), for example:
# CORS_ORIGINS=https://your-frontend-domain.com
